shell=bash
severity=warning
# Disabled rules and why:
# SC1091 - source'd files (ui.sh, etc.) are checked individually; don't warn on dynamic includes.
# SC2317 - functions with unreachable code (e.g. trap handlers) are intentional.
# SC2034 - unused variables are common in module scaffolding; warning-level only.
# SC2154 - variables set by sourced core files are intentionally global; checked by other means.
# SC2155 - declaring+assigning in one line is fine for readability here.
# SC2002 - cat | while is used for clarity in a few log loops.
# SC2188 - heredoc/echo-to-file patterns are intentional.
# SC2046 - word-splitting in command substitution is required for some tool outputs.
# SC2012 - ls | wc -l used only for human-facing counts, not logic.
# SC2254 - glob expansion in case patterns is intended.
# SC2015 - A && B || C chains are used deliberately for short-circuit UX messages.
# SC2001 - sed substitution kept for portability over ${var//pat/str} in a few spots.
# SC2126 - grep | wc -l simplified intentionally.
# SC2207 - array=( $(cmd) ) used for tool output capture.
# SC2129 - multiple appends to a file in a loop are clearer than a single heredoc here.
# SC2320 - $? after a pipe is intentional in a few status checks.
# SC2318 - unreachable code in trap/cleanup functions.
# SC2027/SC2024 - quoted command substitution in double quotes is intentional.
# SC2199 - array globbing in [[ ]] comparisons is intentional for "any match" checks.
# SC2196 - esac/;; formatting preference.
# SC2236 - -n/-z empty checks kept explicit for readability.
# SC2230 - which is avoided; command -v used instead where relevant.
# SC2102 - ranges in character classes are intentional.
# SC2178 - variable assignment that looks like a glob is intentional.
# SC2145 - array interpolation in function calls is intentional.
# SC2148 - shebang already present in all executable scripts.
# SC2143 - grep -q used intentionally for existence checks.
# SC2174 - mkdir -p mode flag omitted intentionally (umask-based perms).
# SC2119 - function called with no args intentionally (uses globals).
# SC2153 - variable name similarity is intentional (e.g. DB_DIR vs DB_FILE).
disable=SC1091,SC2317,SC2034,SC2154,SC2155,SC2002,SC2188,SC2046,SC2012,SC2254,SC2015,SC2001,SC2126,SC2207,SC2129,SC2320,SC2318,SC2027,SC2024,SC2199,SC2196,SC2236,SC2230,SC2102,SC2178,SC2145,SC2148,SC2143,SC2174,SC2119,SC2153
